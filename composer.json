{
  "name": "vnuswilliams/laravel-autolang",
  "description": "Laravel package that scans Blade files, extracts hardcoded UI text, wraps it with __(), and generates JSON translation files automatically.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Vnuswilliams\\LaravelAutoLang\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vnuswilliams\\LaravelAutoLang\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/filesystem": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Vnuswilliams\\LaravelAutoLang\\LaravelAutoLangServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
